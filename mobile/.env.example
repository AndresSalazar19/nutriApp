# Public runtime configuration
# Web/local browser:
EXPO_PUBLIC_API_URL=http://localhost:8083

# Expo Go on a physical phone:
# EXPO_PUBLIC_API_URL=http://YOUR_PC_IPV4:8083

# Shared remote server:
# EXPO_PUBLIC_API_URL=http://147.93.176.210:8083

# Local EAS project binding (not credentials)
EAS_OWNER=your-expo-account-or-team
EAS_PROJECT_ID=00000000-0000-0000-0000-000000000000
